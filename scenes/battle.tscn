script = ExtResource("1")

[node name="EnemyArea" type="VBoxContainer" parent="."]
layout_mode = 2

[node name="EnemyLabel" type="Label" parent="EnemyArea"]
layout_mode = 2
text = "歌布靈戰士  HP: 20 / 20"
